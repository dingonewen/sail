{
  "name": "@sail/api",
  "version": "0.1.0",
  "private": true,
  "description": "Sail HTTP API — Fastify server with async job queue",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@sail/core": "workspace:*",
    "fastify": "^5.3.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.2.0",
    "@fastify/swagger": "latest",
    "@fastify/swagger-ui": "latest",
    "bullmq": "latest",
    "ioredis": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "latest",
    "vitest": "latest"
  }
}
