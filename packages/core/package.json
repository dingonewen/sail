  "dependencies": {
    "@mastra/core": "latest",
    "@mastra/libsql": "latest",
    "@mastra/memory": "latest",
    "@mastra/observability": "latest",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "latest",
    "vitest": "latest"
  }
