{
  "name": "@sail/core",
  "version": "0.1.0",
  "private": true,
  "description": "Sail agent core — Agent, tools, memory, and observability powered by Mastra",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
